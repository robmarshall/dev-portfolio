":"Inspiration"}],"tags":[{"name":"Animated"},{"name":"Coding"},{"name":"CSS"},{"name":"Design"},{"name":"Features"},{"name":"Highlights"},{"name":"Inspiration"},{"name":"JS"},{"name":"Menu"},{"name":"Purple"},{"name":"Snippets"},{"name":"Visualiser"}]}},{"node":{"id":"c80c112a-50b5-52bc-9ba6-380b4c3a32eb","slug":"creative-and-development-inspiration-4-hidden-menus","template":"","format":"standard","title":"Creative and Development Inspiration 4: Hidden Menus","date":"2017-11-13, 10:05:25","modified":"2017-11-13, 13:48:40","excerpt":"<p>Today&#8217;s post is focusing on code snippets for hidden menus. These could be used on both mobile and large devices. Although they are not particularly attractive menus, I am focusing more on the usability and style. The purpose is to help inspire. &nbsp; Simple multilevel menu This menu is a code snippet from Cody House. [&hellip;]</p>\n","featured_media":{"localFile":{"childImageSharp":{"fluid":{"base64":"data:image/jpeg;base64,","aspectRatio":1.829268292682927,"src":"/static/5eccdd0964125c62a43ad3f876db702c/db7af/Google-Material-Mobile-Menus.jpg","srcSet":"/static/5eccdd0964125c62a43ad3f876db702c/8f9a6/Google-Material-Mobile-Menus.jpg 250w,\n/static/5eccdd0964125c62a43ad3f876db702c/6a7a1/Google-Material-Mobile-Menus.jpg 500w,\n/static/5eccdd0964125c62a43ad3f876db702c/db7af/Google-Material-Mobile-Menus.jpg 750w","sizes":"(max-width: 750px) 100vw, 750px"}}},"title":"Google Material Mobile Menus","alt_text":"Google Material Mobile Menus"},"categories":[{"name":"Coding"},{"name":"Creative"},{"name":"General Coding"}],"tags":[{"name":"Coding"},{"name":"CSS"},{"name":"Design"},{"name":"Google"},{"name":"Hover"},{"name":"JS"},{"name":"Material"},{"name":"Menu"},{"name":"Mouseover"}]}}],"pathPrefix":"tag","first":true,"last":true,"index":1,"pageCount":1,"additionalContext":{"tagName":"Menu"}}}